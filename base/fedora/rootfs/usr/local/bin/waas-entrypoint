#!/usr/bin/env bash
# waas-entrypoint — renders runtime config from env, then execs supervisord.
#
# Everything mutable lives under $WAAS_RUNTIME_DIR (default /tmp/waas) so
# the image runs with a read-only rootfs given three writable mounts:
#   /home/user  (PVC, mounted by the operator)
#   /tmp        (emptyDir/tmpfs)
#   /run        (emptyDir/tmpfs — only needed when RDP is enabled)
#
# Secrets are runtime-only: the desktop password arrives via env
# (VNC_PW / VNC_PASSWORD / RDP_PASSWORD), is written 0600 into the runtime
# dir in VNC-hashed form, and is scrubbed from the environment before any
# service starts.
set -euo pipefail

log()  { printf 'waas-entrypoint: %s\n' "$*" >&2; }
fail() { log "FATAL: $*"; exit 1; }

RUNDIR="${WAAS_RUNTIME_DIR:-/tmp/waas}"
umask 077
mkdir -p "${RUNDIR}/supervisor.d" "${RUNDIR}/xrdp"

# ---------------------------------------------------------------- password
# Single session password shared by both protocols (the xrdp libvnc bridge
# forwards the RDP password as the VNC password, so they cannot differ).
# A password is ALWAYS required — no image ever boots with an open session.
PASSWORD="${VNC_PW:-${VNC_PASSWORD:-${RDP_PASSWORD:-}}}"
[[ -n "${PASSWORD}" ]] || fail "no desktop password: set VNC_PW (or RDP_PASSWORD) from a Kubernetes Secret"
printf '%s\n' "${PASSWORD}" | vncpasswd -f > "${RUNDIR}/vnc.passwd"
chmod 0600 "${RUNDIR}/vnc.passwd"

# RDP client authentication. Enabled at build time (ENV RDP_AUTH_ENABLED=true
# in the base image): the RDP client must present the session password,
# which the xrdp libvnc bridge forwards to Xvnc (password=ask). Setting
# RDP_AUTH_ENABLED=false at RUNTIME is the only way to get credential-less
# RDP: the bridge then authenticates to Xvnc itself and any client reaching
# :3389 gets the session — an explicit, logged opt-out for lab setups.
RDP_AUTH="${RDP_AUTH_ENABLED:-true}"
[[ "${RDP_AUTH}" == "true" || "${RDP_AUTH}" == "false" ]] \
    || fail "RDP_AUTH_ENABLED must be 'true' or 'false', got '${RDP_AUTH}'"
RDP_AUTOLOGIN_PASSWORD=""
if [[ "${RDP_AUTH}" == "false" && "${WAAS_RDP_ENABLED:-0}" == "1" ]]; then
    RDP_AUTOLOGIN_PASSWORD="${PASSWORD}"
fi

# Scrub: children of supervisord must not inherit the cleartext secret
# (visible in /proc/*/environ to anything running in the session).
unset PASSWORD VNC_PW VNC_PASSWORD RDP_PASSWORD
export VNC_PW='' VNC_PASSWORD='' RDP_PASSWORD=''

# -------------------------------------------------------------- X authority
# Proper cookie auth for the X display instead of Xvnc -ac.
export XAUTHORITY="${RUNDIR}/Xauthority"
: > "${XAUTHORITY}"
xauth add "${DISPLAY:-:1}" MIT-MAGIC-COOKIE-1 "$(head -c16 /dev/urandom | od -An -tx1 | tr -d ' \n')"

# ------------------------------------------------------------------- home
# First boot on a fresh PVC: the volume shadows the baked home, so seed it.
if [[ ! -e "${HOME}/.profile" ]]; then
    log "seeding empty home from /etc/skel"
    cp -rT /etc/skel "${HOME}" 2>/dev/null || true
fi
mkdir -p "${HOME}/Desktop" 2>/dev/null || true

# ------------------------------------------------------------------- Xvnc
RESOLUTION="${VNC_RESOLUTION:-1920x1080}"
DEPTH="${VNC_COL_DEPTH:-24}"
[[ "${RESOLUTION}" =~ ^[0-9]+x[0-9]+$ ]] || fail "VNC_RESOLUTION must look like 1920x1080, got '${RESOLUTION}'"

# Xvnc always runs — it is the display server. WAAS_VNC_ENABLED=0 does not
# stop it, it binds it to localhost so only the in-pod xrdp bridge can
# reach it and the operator's TCP probe must target 3389 instead.
VNC_SCOPE_FLAG=""
if [[ "${WAAS_VNC_ENABLED:-1}" != "1" ]]; then
    [[ "${WAAS_RDP_ENABLED:-0}" == "1" ]] || fail "both WAAS_VNC_ENABLED and WAAS_RDP_ENABLED are off: nothing would be reachable"
    VNC_SCOPE_FLAG="-localhost"
    log "VNC disabled for external clients (Xvnc bound to localhost for the xrdp bridge)"
fi

# -UseBlacklist=0: the operator's Kubernetes TCP probe against this same
# port opens a bare connection every few seconds without completing the
# VncAuth handshake. TigerVNC counts that as a failed auth attempt and,
# after BlacklistThreshold (default 5), blacklists the probe's source —
# which then also blocks real guacd connections routed through the same
# address. The port is never internet-facing (only the in-cluster
# ClusterIP Service, itself gated by the api-server's connection-token
# flow), so disabling VNC's own brute-force lockout here is safe.
cat > "${RUNDIR}/supervisor.d/10-xvnc.conf" <<EOF
[program:xvnc]
command=/usr/bin/Xvnc ${DISPLAY:-:1} -geometry ${RESOLUTION} -depth ${DEPTH} -rfbport 5901 ${VNC_SCOPE_FLAG} -rfbauth ${RUNDIR}/vnc.passwd -SecurityTypes VncAuth -AlwaysShared -UseBlacklist=0 -auth ${XAUTHORITY} -desktop waas
priority=10
autorestart=true
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
redirect_stderr=true
EOF

# ------------------------------------------------------------------ audio
# PulseAudio in plain user mode: no root, no setuid, no rtkit — the same
# privilege profile as everything else here. Apps play into a null sink
# (rendered policy below), guacd streams its monitor by connecting to the
# native protocol on TCP 4713 (guacd params enable-audio /
# audio-servername). Module loading is frozen after startup so neither an
# in-session client nor a network peer can extend the daemon.
PULSE_ENV=""
if [[ "${WAAS_AUDIO_ENABLED:-1}" == "1" ]]; then
    command -v pulseaudio >/dev/null || fail "WAAS_AUDIO_ENABLED=1 but pulseaudio is not in this image"
    mkdir -p "${RUNDIR}/pulse"
    sed "s|@RUNDIR@|${RUNDIR}|g" /etc/waas/pulse/default.pa.tpl > "${RUNDIR}/pulse/default.pa"
    # Session apps reach the daemon through the unix socket, never TCP.
    PULSE_ENV=",PULSE_SERVER=\"unix:${RUNDIR}/pulse/native\""
    cat > "${RUNDIR}/supervisor.d/15-pulseaudio.conf" <<EOF
[program:pulseaudio]
command=/usr/bin/pulseaudio --daemonize=no --exit-idle-time=-1 --disallow-exit=yes --disallow-module-loading=yes --log-target=stderr -nF ${RUNDIR}/pulse/default.pa
priority=15
autorestart=true
environment=HOME="${HOME}",PULSE_RUNTIME_PATH="${RUNDIR}/pulse/runtime",PULSE_STATE_PATH="${RUNDIR}/pulse/state"
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
redirect_stderr=true
EOF
fi

# ---------------------------------------------------------------- session
cat > "${RUNDIR}/supervisor.d/20-session.conf" <<EOF
[program:session]
command=/usr/local/bin/waas-session
priority=20
autorestart=true
startretries=10
environment=DISPLAY="${DISPLAY:-:1}",XAUTHORITY="${XAUTHORITY}",HOME="${HOME}"${PULSE_ENV}
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
redirect_stderr=true
EOF

# ------------------------------------------------------------------- xrdp
if [[ "${WAAS_RDP_ENABLED:-0}" == "1" ]]; then
    command -v xrdp >/dev/null || fail "WAAS_RDP_ENABLED=1 but xrdp is not in this image (build with INSTALL_RDP=1)"

    # xrdp reads /etc/xrdp/xrdp.ini at a fixed path; the image bakes it as
    # a symlink to /tmp/waas/xrdp/xrdp.ini. Keep that valid if the runtime
    # dir was relocated.
    [[ "${RUNDIR}" == "/tmp/waas" ]] || ln -sfn "${RUNDIR}" /tmp/waas

    # TLS: use an operator/ESO-provided cert when mounted, otherwise
    # generate an ephemeral self-signed pair. Fine for the default threat
    # model (guacd is the only client, inside the cluster); see README.
    if [[ -n "${WAAS_TLS_CERT:-}" && -n "${WAAS_TLS_KEY:-}" ]]; then
        ln -sf "${WAAS_TLS_CERT}" "${RUNDIR}/xrdp/cert.pem"
        ln -sf "${WAAS_TLS_KEY}"  "${RUNDIR}/xrdp/key.pem"
    else
        openssl req -x509 -newkey rsa:2048 -nodes -days 3650 \
            -subj "/CN=waas-workspace" \
            -keyout "${RUNDIR}/xrdp/key.pem" -out "${RUNDIR}/xrdp/cert.pem" 2>/dev/null
    fi
    xrdp-keygen xrdp "${RUNDIR}/xrdp/rsakeys.ini" >/dev/null

    # Render xrdp.ini from the packaged template (the /etc/xrdp/xrdp.ini
    # symlink baked in the image points at the rendered copy).
    sed "s|@RUNDIR@|${RUNDIR}|g" /etc/waas/xrdp/xrdp.ini.tpl > "${RUNDIR}/xrdp/xrdp.ini"
    chmod 0600 "${RUNDIR}/xrdp/xrdp.ini"
    if [[ "${RDP_AUTH}" == "false" ]]; then
        # Explicit opt-out (RDP_AUTH_ENABLED=false): bake the session
        # password into the bridge config so RDP clients connect without
        # credentials. Whole-line equality in pure bash — no sed/awk, so
        # the password stays a literal whatever characters it contains,
        # and comments mentioning the marker can never be corrupted.
        log "WARNING: RDP authentication DISABLED (RDP_AUTH_ENABLED=false) — any client reaching :3389 gets the session"
        while IFS= read -r line; do
            [[ "${line}" == "password=ask" ]] && line="password=${RDP_AUTOLOGIN_PASSWORD}"
            printf '%s\n' "${line}"
        done < "${RUNDIR}/xrdp/xrdp.ini" > "${RUNDIR}/xrdp/xrdp.ini.rendered"
        mv "${RUNDIR}/xrdp/xrdp.ini.rendered" "${RUNDIR}/xrdp/xrdp.ini"
        chmod 0600 "${RUNDIR}/xrdp/xrdp.ini"
        unset RDP_AUTOLOGIN_PASSWORD line
    fi
    mkdir -p /run/xrdp/sockdir 2>/dev/null || true

    cat > "${RUNDIR}/supervisor.d/30-xrdp.conf" <<EOF
[program:xrdp]
command=/usr/sbin/xrdp --nodaemon
priority=30
autorestart=true
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
redirect_stderr=true
EOF
fi

# ------------------------------------------------------------- extensions
# Layer hook: derived images (dev-ssh, ...) drop scripts into
# /etc/waas/entrypoint.d/ to render their own supervisor fragments and
# runtime config. Sourced (not exec'd) so they share this script's env,
# helpers (log/fail) and strict mode.
if [[ -d /etc/waas/entrypoint.d ]]; then
    for hook in /etc/waas/entrypoint.d/*.sh; do
        [[ -e "${hook}" ]] || continue
        log "entrypoint hook: $(basename "${hook}")"
        # shellcheck disable=SC1090
        source "${hook}"
    done
fi

log "starting services (vnc external: ${WAAS_VNC_ENABLED:-1}, rdp: ${WAAS_RDP_ENABLED:-0}, audio: ${WAAS_AUDIO_ENABLED:-1}, resolution: ${RESOLUTION})"
exec supervisord -n -c /etc/waas/supervisord.conf
