#!/usr/bin/env bash
# waas-session — the graphical session, run by supervisord on DISPLAY :1.
#
# Layering contract: derived images customise the session by setting the
# WAAS_STARTUP env var (e.g. the XFCE image sets it to startxfce4). The
# base fallback is openbox + xterm: enough to prove the display pipeline
# works and to host a single maximised app.
set -euo pipefail

# Xvnc (supervisord priority 10) starts concurrently and takes a moment
# to accept connections; nothing below survives starting first. If X is
# unreachable, dbus-launch --exit-with-session kills its fresh
# dbus-daemon instantly, and xfce4-session — whose own X connect lands
# a beat later, when Xvnc IS up — inherits the dead bus address and
# greets the first connection with an "Unable to contact settings
# server" dialog. vncconfig would silently die too (no clipboard).
# xrandr is the probe both variants ship (it is what waas-resize uses).
for _ in $(seq 1 50); do
    xrandr --query >/dev/null 2>&1 && break
    sleep 0.2
done

# vncconfig bridges the X selection to the RFB clipboard (guac <-> apps).
vncconfig -nowin &

if [[ -n "${WAAS_STARTUP:-}" ]]; then
    # dbus-launch gives apps/DEs the session bus they expect; it exits
    # with the session so supervisord restart semantics stay correct.
    # Word splitting is intentional: WAAS_STARTUP may carry arguments.
    # shellcheck disable=SC2086
    exec dbus-launch --exit-with-session ${WAAS_STARTUP}
fi

openbox &
exec xterm -geometry 120x30
