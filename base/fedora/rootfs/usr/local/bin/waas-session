#!/usr/bin/env bash
# waas-session — the graphical session, run by supervisord on DISPLAY :1.
#
# Layering contract: derived images customise the session by setting
# exactly ONE of:
#   WAAS_STARTUP — full session command (the XFCE image sets startxfce4)
#   WAAS_APP     — single-app mode: openbox under the kiosk config plus
#                  the app, which IS the session (exit => restart)
# The base fallback is openbox + xterm: enough to prove the display
# pipeline works.
set -euo pipefail

# Xvnc (supervisord priority 10) starts concurrently and takes a moment
# to accept connections; nothing below survives starting first. If X is
# unreachable, dbus-launch --exit-with-session kills its fresh
# dbus-daemon instantly, and xfce4-session — whose own X connect lands
# a beat later, when Xvnc IS up — inherits the dead bus address and
# greets the first connection with an "Unable to contact settings
# server" dialog. vncconfig would silently die too (no clipboard).
# xrandr is the probe both variants ship (it is what waas-resize uses).
for _ in {1..50}; do
    xrandr --query >/dev/null 2>&1 && break
    sleep 0.2
done

if [[ -n "${WAAS_APP:-}" && -n "${WAAS_STARTUP:-}" ]]; then
    echo "waas-session: FATAL: both WAAS_APP and WAAS_STARTUP are set — a derived image must pick one" >&2
    exit 1
fi

# vncconfig bridges the X selection to the RFB clipboard (guac <-> apps).
vncconfig -nowin &

if [[ -n "${WAAS_APP:-}" ]]; then
    # Single-app (Kasm-style) mode: the kiosk openbox config undecorates
    # and maximises every normal window, binds no keys and no root menu;
    # dialogs stay dialogs. There is no desktop in the image to reach.
    # xsetroot paints a neutral backdrop for the instant before the app
    # maps (Ubuntu has it via x11-xserver-utils; Fedora's exploded
    # package set may not, hence the guard).
    if command -v xsetroot >/dev/null; then
        xsetroot -solid "#1f2430"
    fi
    # --replace: on an app respawn the previous run's openbox is still
    # managing the display; converge on the fresh one instead of leaving
    # a zombie child of the app.
    openbox --replace --config-file /etc/waas/openbox-app.rc.xml &
    # dbus-run-session, not dbus-launch: the bus lives exactly as long
    # as the app. dbus-launch --exit-with-session ties it to the X
    # server instead, leaking one dbus-daemon per app exit — and closing
    # the app is a normal user action in this mode (supervisord then
    # restarts the session).
    # Word splitting is intentional: WAAS_APP may carry arguments.
    # shellcheck disable=SC2086
    exec dbus-run-session -- ${WAAS_APP}
fi

if [[ -n "${WAAS_STARTUP:-}" ]]; then
    # dbus-launch gives apps/DEs the session bus they expect; it exits
    # with the session so supervisord restart semantics stay correct.
    # Word splitting is intentional: WAAS_STARTUP may carry arguments.
    # shellcheck disable=SC2086
    exec dbus-launch --exit-with-session ${WAAS_STARTUP}
fi

openbox &
exec xterm -geometry 120x30
